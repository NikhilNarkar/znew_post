<mvc:View
    controllerName="znewpost.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:f="sap.ui.layout.form">

    <Page
        id="page"
        title="Transfer Posting 311 E Against Reservation">

        <content>
            <VBox id="_IDGenVBox"
    width="100%"
    fitContainer="true"
    class="sapUiContentPadding">

                <!-- Header -->
                <ObjectHeader id="_IDGenObjectHeader"
                    title="Transfer Posting 311 E"
                    intro="Against Reservation"
                    icon="sap-icon://shipping-status"
                    responsive="true"
                    class="sapUiSmallMarginBottom" />

                <!-- Reservation Details -->
                <Panel id="_IDGenPanel"
    width="100%"
    headerText="Reservation Details"
    expandable="false"
    class="sapUiContentPadding">

                    <content>
                        <f:SimpleForm id="_IDGenSimpleForm"
    editable="true"
    layout="ResponsiveGridLayout"
    columnsXL="1"
    columnsL="1"
    columnsM="1"
    columnsS="1"
    labelSpanXL="2"
    labelSpanL="2"
    labelSpanM="2"
    labelSpanS="12"
    adjustLabelSpan="false"
    emptySpanXL="0"
    emptySpanL="0"
    emptySpanM="0"
    emptySpanS="0"
    singleContainerFullSize="true">

    <Label id="_IDGenLabel"
        text="Reservation Number"
        required="true"/>

    <Input
        width="100%"
        id="inputReservation"
        value="{local>/selection/reservation}"
        placeholder="Enter reservation number"
        change=".onReservationChange"/>

    <Label id="_IDGenLabel1"
        text="Posting Date"
        required="true"/>

    <DatePicker
        width="100%"
        id="dpPostingDate"
        value="{
            path:'local>/selection/postingDate',
            type:'sap.ui.model.type.Date',
            formatOptions:{pattern:'MM/dd/yyyy'}
        }"
        displayFormat="MM/dd/yyyy"/>

    <Label id="_IDGenLabel2" text="Sales Order"/>
    <Input id="_IDGenInput"
        width="100%"
        value="{local>/selection/salesOrder}"
        editable="false"/>

    <Label id="_IDGenLabel3" text="Production Order"/>
    <Input id="_IDGenInput1"
        width="100%"
        value="{local>/selection/productionOrder}"
        editable="false"/>

    <Label id="_IDGenLabel4" text="Lot Number"/>
    <Input id="_IDGenInput2"
        width="100%"
        value="{local>/selection/lotNumber}"
        editable="false"/>

    <Label id="_IDGenLabel5" text="Plant"/>
    <Input id="_IDGenInput3"
        width="100%"
        value="{local>/selection/headerPlant}"
        editable="false"/>

</f:SimpleForm>
                    </content>
                </Panel>

                <!-- Information -->
                <MessageStrip id="_IDGenMessageStrip"
                    text="Enter reservation number to load items. Scan or enter batch to auto-fill issued quantity, unit, and issue location."
                    type="Information"
                    showIcon="true"
                    class="sapUiSmallMarginTop sapUiSmallMarginBottom" />

                <!-- Reservation Items -->
                <Panel id="_IDGenPanel1"
                    expandable="false"
                    class="sapUiResponsiveMargin"
                    headerText="Reservation Items">

                    <content>
                        <Table
                            id="batchesTable"
                            items="{local>/scannedBatches}"
                             mode="MultiSelect"
                            growing="true"
                            growingThreshold="20"
                            alternateRowColors="true"
                            sticky="ColumnHeaders,HeaderToolbar"
                            noDataText="No reservation items found."
                            inset="false">


                            <headerToolbar>
                                <OverflowToolbar id="_IDGenOverflowToolbar">
                                    <Title id="_IDGenTitle"
    text="{= 'Reservation Items (' + ${local>/scannedBatches}.length + ')' }"
    level="H2" />
                                    <ToolbarSpacer id="_IDGenToolbarSpacer" />
                                       <Button
            id="btnDelete"
            text="Delete"
            icon="sap-icon://delete"
            type="Reject"
            press=".onDeleteSelected" />
                                    <ObjectStatus id="_IDGenObjectStatus"
                                        text="Ready"
                                        state="Success" />
                                </OverflowToolbar>
                            </headerToolbar>

                            <columns>
                                <Column id="_IDGenColumn1" width="14rem">
                                    <HBox id="_IDGenHBox" alignItems="Center">
                                        <core:Icon id="_IDGenIcon" src="sap-icon://product" />
                                        <Text id="_IDGenText"
                                            text="Material"
                                            class="sapUiTinyMarginBegin" />
                                    </HBox>
                                </Column>

                                <Column id="_IDGenColumn2" width="18rem">
                                    <HBox id="_IDGenHBox1" alignItems="Center">
                                        <core:Icon id="_IDGenIcon1" src="sap-icon://document-text" />
                                        <Text id="_IDGenText1"
                                            text="Description"
                                            class="sapUiTinyMarginBegin" />
                                    </HBox>
                                </Column>

                                <Column id="_IDGenColumn3"
                                    width="8rem"
                                    hAlign="End">
                                    <HBox id="_IDGenHBox2" alignItems="Center">
                                        <core:Icon id="_IDGenIcon2" src="sap-icon://measure" />
                                        <Text id="_IDGenText2"
                                            text="Required Qty"
                                            class="sapUiTinyMarginBegin" />
                                    </HBox>
                                </Column>

                                <Column id="_IDGenColumn4" width="5rem">
                                    <Text id="_IDGenText3" text="Req UoM" />
                                </Column>

                                <Column id="_IDGenColumn5" width="10rem">
                                    <HBox id="_IDGenHBox3" alignItems="Center">
                                        <core:Icon id="_IDGenIcon3" src="sap-icon://batch-payments" />
                                        <Text id="_IDGenText4"
                                            text="From Batch"
                                            class="sapUiTinyMarginBegin" />
                                    </HBox>
                                </Column>

                                <Column id="_IDGenColumn6" width="10rem">
                                    <HBox id="_IDGenHBox4" alignItems="Center">
                                        <core:Icon id="_IDGenIcon4" src="sap-icon://batch-payments" />
                                        <Text id="_IDGenText5"
                                            text="To Batch"
                                            class="sapUiTinyMarginBegin" />
                                    </HBox>
                                </Column>

                                <Column id="_IDGenColumn7" width="10rem">
                                    <Text id="_IDGenText6" text="Issued Qty" />
                                </Column>

                                <Column id="_IDGenColumn8" width="6rem">
                                    <Text id="_IDGenText7" text="Issue UoM" />
                                </Column>

                                <!-- <Column
                                    width="7rem"
                                    minScreenWidth="Tablet"
                                    demandPopin="true">
                                    <HBox alignItems="Center">
                                        <core:Icon src="sap-icon://factory" />
                                        <Text
                                            text="Plant"
                                            class="sapUiTinyMarginBegin" />
                                    </HBox>
                                </Column> -->

                                <Column id="_IDGenColumn9" width="10rem">
                                    <Text id="_IDGenText8" text="Issue Location" />
                                </Column>

                                <Column id="_IDGenColumn10"
                                    width="11rem"
                                    minScreenWidth="Tablet"
                                    demandPopin="true">
                                    <Text id="_IDGenText9" text="Receiving Location" />
                                </Column>

                                <Column id="_IDGenColumn11"
                                    width="9rem"
                                    minScreenWidth="Desktop"
                                    demandPopin="true">
                                    <Text id="_IDGenText10" text="Sales Order" />
                                </Column>

                                <Column id="_IDGenColumn12"
                                    width="11rem"
                                    minScreenWidth="Desktop"
                                    demandPopin="true">
                                    <Text id="_IDGenText11" text="Sales Order Item" />
                                </Column>

                                <Column id="_IDGenColumn13"
                                    width="12rem"
                                    minScreenWidth="Desktop"
                                    demandPopin="true">
                                    <Text id="_IDGenText12" text="Production Order" />
                                </Column>
                            </columns>

                            <items>
                                <ColumnListItem id="_IDGenColumnListItem"
                                    type="Inactive"
                                    vAlign="Middle">

                                    <cells>
                                        <Text id="_IDGenText13" text="{local>material}" />

                                        <Text id="_IDGenText14" text="{local>description}" />

                                        <ObjectNumber id="_IDGenObjectNumber"
                                            number="{local>requiredQty}"
                                             />

                                        <Text id="_IDGenText15" text="{local>reqUom}" />

                                       <Input id="_IDGenInput4"
    value="{local>batch}"
    placeholder="Scan / Enter Batch"
    showValueHelp="true"
    valueHelpRequest=".onFromBatchValueHelp"
    change=".onBatchChange"
    editable="true" />

                                            <Input id="_IDGenInput5"
                value="{local>toBatch}"
                placeholder="Enter To Batch"
                editable="true" />



                                        <Input id="_IDGenInput6"
    value="{local>issuedQty}"
    type="Number"
    placeholder="Issued Qty"
    liveChange=".onIssuedQtyChange"
    change=".onIssuedQtyChange" />

                                        <Text id="_IDGenText16" text="{local>uom}" />

                                        <!-- <ObjectIdentifier
                                            title="{local>plant}" /> -->

                                        <Input id="_IDGenInput7"
                                            value="{local>issueLocation}"
                                            placeholder="Issue Location"
                                            change=".onIssueLocationChange" />

                                        <Text id="_IDGenText17" text="{local>receivingLocation}" />

                                        <Text id="_IDGenText18" text="{local>salesOrder}" />

                                        <Text id="_IDGenText19" text="{local>salesOrderItem}" />

                                        <Text id="_IDGenText20" text="{local>productionOrder}" />
                                    </cells>
                                </ColumnListItem>
                            </items>
                        </Table>
                    </content>
                </Panel>
            </VBox>
        </content>

        <footer>
            <OverflowToolbar id="_IDGenOverflowToolbar1">
                <ToolbarSpacer id="_IDGenToolbarSpacer1" />

                <Button
                    id="btnNew"
                    text="New"
                    icon="sap-icon://add-document"
                    type="Transparent"
                    press=".onNew" />

                <Button
                    id="btnSubmit"
                    text="Submit"
                    icon="sap-icon://accept"
                    type="Emphasized"
                    press=".onSubmit" />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>