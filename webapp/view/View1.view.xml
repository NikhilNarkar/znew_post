<mvc:View
controllerName="znewpost.controller.View1"
xmlns:mvc="sap.ui.core.mvc"
xmlns="sap.m"
xmlns:core="sap.ui.core"
xmlns:f="sap.ui.layout.form">

<Page
id="page"
title="Transfer Posting 311 E Against Reservation">

<content>
<VBox id="_IDGenVBox"
width="100%"
fitContainer="true"
class="sapUiContentPadding">

<!-- Header -->
<ObjectHeader id="_IDGenObjectHeader"
title="Transfer Posting 311 E"
intro="Against Reservation"
icon="sap-icon://shipping-status"
responsive="true"
class="sapUiSmallMarginBottom" />

<!-- Reservation Details -->
<Panel id="_IDGenPanel"
width="100%"
headerText="Reservation Details"
expandable="false"
class="sapUiContentPadding">

<content>
<HBox id="_IDGenHBox6"
width="100%"
wrap="Wrap"
alignItems="End"
justifyContent="Start"
class="sapUiSmallMarginTop sapUiSmallMarginBottom">

<VBox id="_IDGenVBox1" width="9rem" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
<Label id="_IDGenLabel" text="Reservation No." required="true" />
<Input
id="inputReservation"
value="{local>/selection/reservation}"
placeholder="Reservation"
change=".onReservationChange"
width="8.5rem" />
</VBox>

<VBox id="_IDGenVBox2" width="8rem" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
<Label id="_IDGenLabel1" text="Posting Date" required="true" />
<DatePicker
id="dpPostingDate"
value="{
path:'local>/selection/postingDate',
type:'sap.ui.model.type.Date',
formatOptions:{pattern:'MM/dd/yyyy'}
}"
displayFormat="MM/dd/yyyy"
width="7.5rem" />
</VBox>

<VBox id="_IDGenVBox3" width="9rem" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
<Label id="_IDGenLabel2" text="Sales Order" />
<Input id="_IDGenInput"
value="{local>/selection/salesOrder}"
editable="false"
width="8.5rem" />
</VBox>

<VBox id="_IDGenVBox4" width="10rem" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
<Label id="_IDGenLabel3" text="Production Order" />
<Input id="_IDGenInput1"
value="{local>/selection/productionOrder}"
editable="false"
width="9.5rem" />
</VBox>

<VBox id="_IDGenVBox5" width="8rem" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
<Label id="_IDGenLabel4" text="Lot Number" />
<Input id="_IDGenInput2"
value="{local>/selection/lotNumber}"
editable="false"
width="7.5rem" />
</VBox>

<VBox id="_IDGenVBox6" width="6rem" class="sapUiTinyMarginEnd sapUiTinyMarginBottom">
<Label id="_IDGenLabel5" text="Plant" />
<Input id="_IDGenInput3"
value="{local>/selection/headerPlant}"
editable="false"
width="5.5rem" />
</VBox>
</HBox>
</content>

</Panel>

<!-- Information -->
<MessageStrip id="_IDGenMessageStrip"
text="Enter reservation number to load items. Scan or enter batch to auto-fill issued quantity, unit, and issue location."
type="Information"
showIcon="true"
class="sapUiSmallMarginTop sapUiSmallMarginBottom" />

<!-- Reservation Items -->
<Panel id="_IDGenPanel1"
    expandable="false"
    class="sapUiNoContentPadding"
    headerText="Reservation Items"> 

<content>
<Table
    id="batchesTable"
    items="{local>/scannedBatches}"
    mode="MultiSelect"
    growing="true"
    growingThreshold="20"
    alternateRowColors="true"
    sticky="ColumnHeaders,HeaderToolbar"
    noDataText="No reservation items found."
    inset="false"
    autoPopinMode="true">

    <headerToolbar>
        <OverflowToolbar id="_IDGenOverflowToolbar">
            <Title id="_IDGenTitle"
                text="{= 'Reservation Items (' + ${local>/scannedBatches}.length + ')' }"
                level="H2" />
            <ToolbarSpacer id="_IDGenToolbarSpacer" />
            <Button
                id="btnDelete"
                text="Delete"
                icon="sap-icon://delete"
                type="Reject"
                press=".onDeleteSelected" />
                 <Button
            id="btnExport"
            text="Export"
            icon="sap-icon://excel-attachment"
            type="Transparent"
            press=".onExportExcel" />
            <!-- <ObjectStatus id="_IDGenObjectStatus"
                text="Ready"
                state="Success" /> -->
        </OverflowToolbar>
    </headerToolbar>

    <columns>

        <Column id="_IDGenColumn1" width="10rem" importance="High">
            <Text id="_IDGenText1" text="Material" />
        </Column>

         <Column id="_IDGenColumnResItem" width="8rem" importance="High">
        <Text id="_IDGenTextResItemHdr" text="Reservation Item" />
    </Column>

        <Column id="_IDGenColumn2" width="12rem" importance="Low">
            <Text id="_IDGenText2" text="Description" />
        </Column>

        <Column id="_IDGenColumn3" width="7rem" hAlign="End" importance="High">
            <Text id="_IDGenText3" text="Required Qty" />
        </Column>

        <Column id="_IDGenColumn4" width="5rem" importance="High">
            <Text id="_IDGenText4" text="Req UoM" />
        </Column>

        <Column id="_IDGenColumn5" width="9rem" importance="High">
            <Text id="_IDGenText5" text="From Batch" />
        </Column>

        <Column id="_IDGenColumn6" width="9rem" importance="Low">
            <Text id="_IDGenText6" text="To Batch" />
        </Column>

        <Column id="_IDGenColumn7" width="8rem" importance="High">
            <Text id="_IDGenText7" text="Issued Qty" />
        </Column>

        <Column id="_IDGenColumn8" width="6rem" importance="High">
            <Text id="_IDGenText8" text="Issue UoM" />
        </Column>

        <Column id="_IDGenColumn9" width="8rem" importance="High">
            <Text id="_IDGenText9" text="Issue Location" />
        </Column>

        <Column id="_IDGenColumn10" width="10rem" importance="Low">
            <Text id="_IDGenText10" text="Receiving Location" />
        </Column>

        <Column id="_IDGenColumn11" width="9rem" importance="Low">
            <Text id="_IDGenText11" text="Sales Order" />
        </Column>

        <Column id="_IDGenColumn12" width="8rem" importance="Low">
            <Text id="_IDGenText12" text="Sales Order Item" />
        </Column>

        <Column id="_IDGenColumn13" width="10rem" importance="Low">
            <Text id="_IDGenText21" text="Production Order" />
        </Column>
    </columns>

    <items>
        <ColumnListItem id="_IDGenColumnListItem"
            type="Inactive"
            vAlign="Middle">

            <cells>
                <Text id="_IDGenText13" text="{local>material}" />

                <Text id="_IDGenTextResItem" text="{local>reservation_item}" />

                <Text id="_IDGenText14" text="{local>description}" />

                <ObjectNumber id="_IDGenObjectNumber"
                    number="{local>requiredQty}" />

                <Text id="_IDGenText15" text="{local>reqUom}" />

                <Input id="_IDGenInput4"
                    value="{local>batch}"
                    placeholder="Scan / Enter Batch"
                    width="100%"
                    showValueHelp="true"
                    valueHelpRequest=".onFromBatchValueHelp"
                    change=".onBatchChange"
                    editable="true" />

                <Input id="_IDGenInput5"
                    value="{local>toBatch}"
                    placeholder="Enter To Batch"
                    width="100%"
                    editable="true" />

                <Input id="_IDGenInput6"
                    value="{local>issuedQty}"
                    type="Number"
                    placeholder="Issued Qty"
                    width="100%"
                    liveChange=".onIssuedQtyChange"
                    change=".onIssuedQtyChange" />

                <Text id="_IDGenText16" text="{local>uom}" />

                <Input id="_IDGenInput7"
                    value="{local>issueLocation}"
                    placeholder="Issue Location"
                    width="100%"
                    change=".onIssueLocationChange" />

                <Text id="_IDGenText17" text="{local>receivingLocation}" />

                <Text id="_IDGenText18" text="{local>salesOrder}" />

                <Text id="_IDGenText19" text="{local>salesOrderItem}" />

                <Text id="_IDGenText20" text="{local>productionOrder}" />
            </cells>
        </ColumnListItem>
    </items>
</Table>
</content>
</Panel>
</VBox>
</content>

<footer>
<OverflowToolbar id="_IDGenOverflowToolbar1">
<ToolbarSpacer id="_IDGenToolbarSpacer1" />

<Button
id="btnNew"
text="New"
icon="sap-icon://add-document"
type="Transparent"
press=".onNew" />

<Button
id="btnSubmit"
text="Submit"
icon="sap-icon://accept"
type="Emphasized"
press=".onSubmit" />
 
</OverflowToolbar>
</footer>
</Page>
</mvc:View>